      "cell_type": "code",
      "source": [
        "import copy\n",
        "import numpy as np\n",
        "import torch\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def shuffle_attention_matrix(att_matrix, mode='columns'):\n",
        "    \"\"\"\n",
        "    Shuffle attention matrix while preserving value distribution.\n",
        "\n",
        "    Args:\n",
        "        att_matrix: torch tensor [seq_len, seq_len]\n",
        "        mode:\n",
        "            'columns' -> shuffle columns only\n",
        "            'rows_cols' -> shuffle both rows and columns\n",
        "            'full' -> shuffle all elements\n",
        "\n",
        "    Returns:\n",
        "        shuffled attention matrix\n",
        "    \"\"\"\n",
        "\n",
        "    att = att_matrix.clone()\n",
        "\n",
        "    if mode == 'columns':\n",
        "        perm = torch.randperm(att.shape[1])\n",
        "        att = att[:, perm]\n",
        "\n",
        "    elif mode == 'rows_cols':\n",
        "        perm = torch.randperm(att.shape[0])\n",
        "        att = att[perm][:, perm]\n",
        "\n",
        "    elif mode == 'full':\n",
        "        flat = att.flatten()\n",
        "        perm = torch.randperm(flat.shape[0])\n",
        "        att = flat[perm].reshape(att.shape)\n",
        "\n",
        "    return att\n",
        "\n",
        "\n",
        "def analyze_shuffled_head(\n",
        "        pattern_type,\n",
        "        target_layer,\n",
        "        target_head,\n",
        "        shuffle_mode='columns',\n",
        "        n_repeat=10,\n",
        "        pattern_func=None,\n",
        "        chiral_indices=None\n",
        "):\n",
        "    \"\"\"\n",
        "    Compute shuffled baseline for a specific layer-head pair.\n",
        "    \"\"\"\n",
        "\n",
        "    shuffled_f_scores = []\n",
        "    shuffled_nw_scores = []\n",
        "\n",
        "    print(f\"Running shuffled baseline for <{target_layer},{target_head}> ...\")\n",
        "\n",
        "    for repeat in range(n_repeat):\n",
        "\n",
        "        sum_tp, sum_fp, sum_fn = 0, 0, 0\n",
        "        sum_wocc, sum_total = 0, 0\n",
        "\n",
        "        indices_range = range(len(smiles_data))\n",
        "\n",
        "        if pattern_type == 'chiral' and chiral_indices is not None:\n",
        "            indices_range = chiral_indices.keys()\n",
        "\n",
        "        for index in tqdm(indices_range, leave=False):\n",
        "\n",
        "            data = smiles_data[index]\n",
        "\n",
        "            # Ground truth vector\n",
        "            if pattern_func:\n",
        "                vec2 = pattern_func(index)\n",
        "            else:\n",
        "                vec2 = generate_ground_truth_vector(pattern_type, index)\n",
        "\n",
        "            if vec2.sum().item() == 0:\n",
        "                continue\n",
        "\n",
        "            # Original attention matrices\n",
        "            A_original = data['A'][target_layer, target_head]\n",
        "            M_original = data['M'][target_layer, target_head]\n",
        "\n",
        "            # Shuffle attention\n",
        "            A_shuffled = shuffle_attention_matrix(\n",
        "                A_original,\n",
        "                mode=shuffle_mode\n",
        "            )\n",
        "\n",
        "            M_shuffled = shuffle_attention_matrix(\n",
        "                M_original.float(),\n",
        "                mode=shuffle_mode\n",
        "            ) > 0\n",
        "\n",
        "            # Generate vec1\n",
        "            vec1 = M_shuffled[:, 1:-1].any(0)\n",
        "\n",
        "            # Confusion matrix\n",
        "            TP = torch.logical_and(vec1, vec2).sum().item()\n",
        "            FP = torch.logical_and(vec1, ~vec2).sum().item()\n",
        "            FN = torch.logical_and(~vec1, vec2).sum().item()\n",
        "\n",
        "            # Attention weights\n",
        "            att = torch.where(\n",
        "                M_shuffled > 0,\n",
        "                A_shuffled,\n",
        "                torch.tensor(0.0)\n",
        "            )[:, 1:-1]\n",
        "\n",
        "            idx = torch.where(vec2)[0]\n",
        "\n",
        "            wocc = att[:, idx].sum().item() if len(idx) > 0 else 0\n",
        "            total_att = att.sum().item()\n",
        "\n",
        "            # Aggregate\n",
        "            sum_tp += TP\n",
        "            sum_fp += FP\n",
        "            sum_fn += FN\n",
        "\n",
        "            sum_wocc += wocc\n",
        "            sum_total += total_att\n",
        "\n",
        "        # Metrics\n",
        "        f_measure = (\n",
        "            (2 * sum_tp) /\n",
        "            (2 * sum_tp + sum_fp + sum_fn)\n",
        "        ) if (2 * sum_tp + sum_fp + sum_fn) > 0 else 0\n",
        "\n",
        "        nw_measure = (\n",
        "            sum_wocc / sum_total\n",
        "        ) if sum_total > 0 else 0\n",
        "\n",
        "        shuffled_f_scores.append(f_measure)\n",
        "        shuffled_nw_scores.append(nw_measure)\n",
        "\n",
        "    # Final statistics\n",
        "    baseline_f_mean = np.mean(shuffled_f_scores)\n",
        "    baseline_f_std = np.std(shuffled_f_scores)\n",
        "\n",
        "    baseline_nw_mean = np.mean(shuffled_nw_scores)\n",
        "    baseline_nw_std = np.std(shuffled_nw_scores)\n",
        "\n",
        "    print(\"\\n=== Shuffled Baseline Results ===\")\n",
        "    print(f\"F-measure : {baseline_f_mean:.4f} ± {baseline_f_std:.4f}\")\n",
        "    print(f\"NW-measure: {baseline_nw_mean:.4f} ± {baseline_nw_std:.4f}\")\n",
        "\n",
        "    return (\n",
        "        baseline_f_mean,\n",
        "        baseline_nw_mean,\n",
        "        baseline_f_std,\n",
        "        baseline_nw_std\n",
        "    )\n",
        "\n",
        "\n",
        "def plot_results_with_baseline(\n",
        "        y1,\n",
        "        y2,\n",
        "        baseline_nw,\n",
        "        baseline_f,\n",
        "        title,\n",
        "        save_path=None\n",
        "):\n",
        "    \"\"\"\n",
        "    Plot boxplots with local baseline lines for each metric.\n",
        "    \"\"\"\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(8, 6))\n",
        "\n",
        "    colors = [\"C0\", \"C5\"]\n",
        "\n",
        "    # Boxplot\n",
        "    box = ax.boxplot(\n",
        "        [y1, y2],\n",
        "        patch_artist=True,\n",
        "        # widths=0.5\n",
        "    )\n",
        "\n",
        "    for patch, color in zip(box['boxes'], colors[:2]):\n",
        "        patch.set_facecolor(color)\n",
        "\n",
        "    # Local baseline lines (NOT full-width)\n",
        "    line_width = 0.22\n",
        "\n",
        "    # NW baseline around x=1\n",
        "    ax.hlines(\n",
        "        y=baseline_nw,\n",
        "        xmin=1 - line_width,\n",
        "        xmax=1 + line_width,\n",
        "        linestyles='--',\n",
        "        linewidth=2,\n",
        "        color='C3'\n",
        "    )\n",
        "\n",
        "    # F baseline around x=2\n",
        "    ax.hlines(\n",
        "        y=baseline_f,\n",
        "        xmin=2 - line_width,\n",
        "        xmax=2 + line_width,\n",
        "        linestyles='--',\n",
        "        linewidth=2,\n",
        "        color='C3'\n",
        "    )\n",
        "\n",
        "    # Legend (single entry)\n",
        "    from matplotlib.lines import Line2D\n",
        "\n",
        "    baseline_legend = Line2D(\n",
        "        [0],\n",
        "        [0],\n",
        "        linestyle='--',\n",
        "        color='C3',\n",
        "        linewidth=2,\n",
        "        label='Shuffled baseline'\n",
        "    )\n",
        "\n",
        "    ax.legend(handles=[baseline_legend])\n",
        "\n",
        "    # Labels\n",
        "\n",
        "    ax.set_ylabel('Values', fontsize=10)\n",
        "\n",
        "    ax.set_xlabel('Metrics', fontsize=10)\n",
        "\n",
        "    ax.set_xticklabels(['NW', 'F'])\n",
        "\n",
        "    ax.set_title(title, fontsize=12)\n",
        "\n",
        "    # Outlier labels\n",
        "\n",
        "    outliers_1 = box['fliers'][0].get_data()[1]\n",
        "    outlier_labels_1 = []\n",
        "\n",
        "    for outlier in outliers_1:\n",
        "\n",
        "        outlier_labels_1.append(\n",
        "            get_layer_head_label(\n",
        "                np.array(head_layer_labels)[\n",
        "                    np.where(np.array(y1) == outlier)[0][0]\n",
        "                ]\n",
        "            )\n",
        "        )\n",
        "\n",
        "    outliers_2 = box['fliers'][1].get_data()[1]\n",
        "    outlier_labels_2 = []\n",
        "\n",
        "    for outlier in outliers_2:\n",
        "\n",
        "        outlier_labels_2.append(\n",
        "            get_layer_head_label(\n",
        "                np.array(head_layer_labels)[\n",
        "                    np.where(np.array(y2) == outlier)[0][0]\n",
        "                ]\n",
        "            )\n",
        "        )\n",
        "    # Add labels\n",
        "\n",
        "    for i in range(len(outlier_labels_1)):\n",
        "\n",
        "        if outlier_labels_1[i] in outlier_labels_2:\n",
        "\n",
        "            ax.text(\n",
        "                1.03,\n",
        "                outliers_1[i],\n",
        "                outlier_labels_1[i],\n",
        "                ha='left',\n",
        "                va='center',\n",
        "                fontsize=10,\n",
        "                color='black'\n",
        "            )\n",
        "\n",
        "            ax.text(\n",
        "                2.03,\n",
        "                outliers_2[\n",
        "                    np.where(\n",
        "                        np.array(outlier_labels_2)\n",
        "                        == outlier_labels_1[i]\n",
        "                    )[0][0]\n",
        "                ],\n",
        "                outlier_labels_1[i],\n",
        "                ha='left',\n",
        "                va='center',\n",
        "                fontsize=10,\n",
        "                color='black'\n",
        "            )\n",
        "\n",
        "        else:\n",
        "\n",
        "            ax.text(\n",
        "                1.03,\n",
        "                outliers_1[i],\n",
        "                outlier_labels_1[i],\n",
        "                ha='left',\n",
        "                va='center',\n",
        "                fontsize=10,\n",
        "                color='black'\n",
        "            )\n",
        "\n",
        "    # Save\n",
        "\n",
        "    plt.tight_layout()\n",
        "\n",
        "    if save_path:\n",
        "        plt.savefig(\n",
        "            save_path,\n",
        "            dpi=300,\n",
        "            bbox_inches='tight'\n",
        "        )\n",
        "\n",
        "    plt.show()"
      ],
