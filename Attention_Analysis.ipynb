        "def coulomb_matrix_ensemble(smiles, num_confs=10, max_iters=200, random_seed=42):\n",
        "    \"\"\"\n",
        "    Generate ensemble of Coulomb matrices for diverse conformers.\n",
        "    Returns the average Coulomb matrix across conformers.\n",
        "    \"\"\"\n",
        "    mol = Chem.MolFromSmiles(smiles)\n",
        "    if mol is None:\n",
        "        return None\n",
        "\n",
        "    mol = Chem.AddHs(mol)\n",
        "\n",
        "    # Set random seed for reproducibility\n",
        "    random.seed(random_seed)\n",
        "    np.random.seed(random_seed)\n",
        "\n",
        "    # Generate conformers with ETKDGv3\n",
        "    params = AllChem.ETKDGv3()\n",
        "    params.numThreads = 1\n",
        "    params.randomSeed = random_seed\n",
        "    params.useRandomCoords = True  # Increase diversity\n",
        "\n",
        "    cids = AllChem.EmbedMultipleConfs(mol, numConfs=num_confs, params=params)\n",
        "    if not cids:\n",
        "        return None\n",
        "\n",
        "    # Optimize conformers with MMFF (fallback to UFF)\n",
        "    if AllChem.MMFFHasAllMoleculeParams(mol):\n",
        "        res = AllChem.MMFFOptimizeMoleculeConfs(mol, maxIters=max_iters, numThreads=1)\n",
        "    else:\n",
        "        res = AllChem.UFFOptimizeMoleculeConfs(mol, maxIters=max_iters)\n",
        "\n",
        "    # Get energies and filter failed optimizations\n",
        "    energies = [r[1] if r[0] == 0 else np.inf for r in res]\n",
        "\n",
        "    # Get heavy atom indices (non-hydrogen)\n",
        "    heavy_idx = [i for i, atom in enumerate(mol.GetAtoms()) if atom.GetAtomicNum() != 1]\n",
        "    num_heavy = len(heavy_idx)\n",
        "\n",
        "    coulomb_matrices = []\n",
        "\n",
        "    for conf_id, energy in enumerate(energies):\n",
        "        if energy == np.inf:\n",
        "            continue  # Skip failed conformers\n",
        "\n",
        "        conf = mol.GetConformer(conf_id)\n",
        "\n",
        "        # Get atomic numbers and positions for heavy atoms only\n",
        "        charges = []\n",
        "        positions = []\n",
        "        for idx in heavy_idx:\n",
        "            atom = mol.GetAtomWithIdx(idx)\n",
        "            charges.append(atom.GetAtomicNum())\n",
        "            pos = conf.GetAtomPosition(idx)\n",
        "            positions.append([pos.x, pos.y, pos.z])\n",
        "\n",
        "        positions = np.array(positions)\n",
        "        charges = np.array(charges)\n",
        "\n",
        "        # Compute distance matrix\n",
        "        dists = np.linalg.norm(positions[:, None, :] - positions[None, :, :], axis=-1)\n",
        "        np.fill_diagonal(dists, 1.0)  # avoid division by zero\n",
        "\n",
        "        # Coulomb matrix\n",
        "        cm = np.outer(charges, charges) / dists\n",
        "        np.fill_diagonal(cm, 0.5 * charges ** 2.4)\n",
        "\n",
        "        coulomb_matrices.append(cm)\n",
        "\n",
        "    if len(coulomb_matrices) == 0:\n",
        "        return None\n",
        "\n",
        "    # Return the average Coulomb matrix across conformers\n",
        "    avg_coulomb_matrix = np.mean(coulomb_matrices, axis=0)\n",
        "\n",
        "    return avg_coulomb_matrix\n",
        "\n",
        "\n",
        "def coulomb_matrix(smiles, num_confs=10, max_iters=200, random_seed=42):\n",
        "    \"\"\"\n",
        "    Wrapper function for backward compatibility.\n",
        "    Returns the average Coulomb matrix across multiple conformers.\n",
        "    \"\"\"\n",
        "    return coulomb_matrix_ensemble(smiles, num_confs, max_iters, random_seed)\n",
        "\n",
        "\n",
        "def compute_all_coulomb(smiles_list, n_jobs=8, num_confs=10, max_iters=200):\n",
        "    \"\"\"Compute average Coulomb matrices for all SMILES in parallel\"\"\"\n",
        "    results = Parallel(n_jobs=n_jobs)(\n",
        "        delayed(coulomb_matrix)(smiles, num_confs, max_iters, seed)\n",
        "        for seed, smiles in enumerate(tqdm(smiles_list, desc=\"Computing Coulomb matrices (ensemble)\"))\n",
        "    )\n",
        "    # Filter out None results\n",
        "    coulomb_matrix_list = [cm for cm in results if cm is not None]\n",
        "    valid_indices = [i for i, cm in enumerate(results) if cm is not None]\n",
        "    return coulomb_matrix_list, valid_indices"
      ],
      "metadata": {
        "id": "XVUOtU5lE6g3"
      },
      "execution_count": null,
      "outputs": []
